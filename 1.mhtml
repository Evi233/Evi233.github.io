@-webkit-keyframes f { 
  0% { transform: rotate(0deg); }
  100% { transform: rotate(1turn); }
}

@keyframes f { 
  0% { transform: rotate(0deg); }
  100% { transform: rotate(1turn); }
}

.weui-slider { padding: 15px 18px; user-select: none; }

.weui-slider__inner { position: relative; height: 2px; background-color: var(--weui-FG-3); }

.weui-slider__track { height: 100%; background-color: var(--weui-BRAND); width: 0px; }

.weui-slider__handler { position: absolute; left: 0px; top: 50%; width: 28px; height: 28px; margin-left: -14px; margin-top: -14px; border-radius: 50%; background-color: rgb(255, 255, 255); box-shadow: 0 0 4px var(--weui-FG-3); }

.weui-slider-box { display: flex; -webkit-box-align: center; align-items: center; }

.weui-slider-box .weui-slider { -webkit-box-flex: 1; flex: 1 1 0%; }

.weui-slider-box__value { margin-left: 0.5em; min-width: 24px; color: var(--weui-FG-1); text-align: center; font-size: 14px; }
